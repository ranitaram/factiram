// ===============================
// GENERATOR & DATASOURCE
// ===============================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===============================
// ENUMS
// ===============================

enum IndustryType {
  COMIDA
  SERVICIO
  RETAIL
  TECNICO
}

enum AuditStatus {
  PROYECTO
  EN_MARCHA
}

enum TaxStatus {
  INFORMAL
  RESICO
  PERSONA_FISICA
  PERSONA_MORAL
}

enum DiagnosticCategory {
  RENTABILIDAD
  RIESGO
  MERCADO
  OPERACION
}

enum MessageColor {
  RED
  YELLOW
  GREEN
}

// ==========================================
// MODELOS REQUERIDOS POR AUTH.JS (NEXT-AUTH)
// ==========================================

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===============================
// USER MODEL
// ===============================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  audits    Audit[]
  purchases Purchase[]

  // 👇 AGREGA ESTO
  usuarioNegocios UsuarioNegocio[]

  @@index([email])
}

// ===============================
// AUDIT MODEL
// ===============================

model Audit {
  id       String       @id @default(uuid())
  industry IndustryType
  status   AuditStatus  @default(PROYECTO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketAvg         Decimal @db.Decimal(12, 2)
  costDirectPercent Decimal @db.Decimal(5, 2)
  fixedCosts        Decimal @db.Decimal(12, 2)
  desiredSalary     Decimal @db.Decimal(12, 2)
  marketingSpend    Decimal @default(0) @db.Decimal(12, 2)
  emergencyFund     Int
  operatingDays     Int
  occupancy         Decimal @default(20) @db.Decimal(5, 2)

  visibilityScore  Int
  competitionScore Int
  differentiation  Int

  capacityPerDay Int
  taxStatus      TaxStatus
  digitalScore   Int

  finalScore     Int?
  breakEvenPoint Decimal? @db.Decimal(12, 2)
  ltvCacRatio    Decimal? @db.Decimal(12, 2)
  netProfit      Decimal? @db.Decimal(12, 2)

  fullDiagnosis Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([industry])
  @@index([status])
  @@index([userId])
}

// ===============================
// PURCHASE MODEL (Ventas & Descargas)
// ===============================

model Purchase {
  id String @id @default(uuid())

  // Datos comerciales
  email     String
  productId String
  amount    Decimal @db.Decimal(12, 2)
  status    String  @default("PENDING") // PENDING | PAID | FAILED

  // Mercado Pago
  mpPreferenceId String? @unique
  mpPaymentId    String? @unique

  // Descarga segura
  downloadToken     String?   @unique
  downloadCount     Int       @default(0)
  downloadLimit     Int       @default(3)
  downloadExpiresAt DateTime?
  lastDownloadAt    DateTime?

  // Relación con usuario
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([userId])
  @@index([userId, status])
}

// ===============================
// DIAGNOSTIC MESSAGES ENGINE
// ===============================

model DiagnosticMessage {
  id           Int                @id @default(autoincrement())
  category     DiagnosticCategory
  industry     IndustryType?
  status       AuditStatus?
  minScore     Int
  maxScore     Int
  conditionKey String?
  message      String             @db.Text
  color        MessageColor
  createdAt    DateTime           @default(now())

  @@index([category])
  @@index([industry])
  @@index([status])
}

// ===============================
// FACTIRAM — MODELOS NUEVOS
// Agregar al FINAL del schema.prisma existente
// No modificar nada de lo que ya está arriba
// ===============================

// ── ENUMS FACTIRAM ─────────────────────────────────────

// ===============================
// FACTIRAM — MODELOS NUEVOS
// ===============================

// ── ENUMS FACTIRAM ─────────────────────────────────────

enum RolNegocio {
  DUENO
  CAJERO
}

enum TipoVenta {
  EFECTIVO
  FIADO
}

enum CategoriaGasto {
  RENTA
  LUZ_AGUA
  INTERNET
  SUELDOS
  PUBLICIDAD
  OTROS
}

enum EstadoAcceso {
  TRIAL
  VIGENTE
  VENCIDO
}

// ── MODELOS FACTIRAM ────────────────────────────────────

model Negocio {
  id                 String   @id @default(uuid())
  nombre             String
  slugUrl            String   @unique
  diasLaborales      Int      @default(26)
  inversionMercancia Decimal  @default(0) @db.Decimal(12, 2)
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  suscripcion Suscripcion?
  usuarios    UsuarioNegocio[]
  productos   Producto[]
  costosFijos CostoFijo[]
  ventasDia   VentaDia[]
  cobros      CobroFiado[]

  gastosDia      GastoDia[]
  efectivosCaja  EfectivoCaja[]

  @@index([slugUrl])
}

model Suscripcion {
  id             String       @id @default(uuid())
  negocioId      String       @unique
  trialStartedAt DateTime     @default(now())
  setupPagado    Boolean      @default(false)
  proximoPagoAt  DateTime?
  estadoMensual  EstadoAcceso @default(TRIAL)

  // Preparado para pagos reales
  stripeCustomerId String?
  stripeSubId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
}

model UsuarioNegocio {
  id        String     @id @default(uuid())
  negocioId String
  userId    String?
  rol       RolNegocio
  clave     String?
  createdAt DateTime   @default(now())

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([negocioId])
  @@index([negocioId, rol])
}

model Producto {
  id          String   @id @default(uuid())
  negocioId   String
  nombre      String
  costoCompra Decimal  @db.Decimal(12, 2)
  precioVenta Decimal  @db.Decimal(12, 2)
  piezasDia   Decimal  @default(0) @db.Decimal(8, 2) // ← agregar esta línea
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  negocio Negocio    @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  ventas  VentaDia[]

  @@index([negocioId])
}

model CostoFijo {
  id        String         @id @default(uuid())
  negocioId String
  categoria CategoriaGasto
  monto     Decimal        @db.Decimal(12, 2)
  updatedAt DateTime       @updatedAt

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@index([negocioId])
}

model VentaDia {
  id         String @id @default(uuid())
  negocioId  String
  productoId String

  cantidad       Int
  tipo           TipoVenta
  precioUnitario Decimal   @db.Decimal(12, 2)
  total          Decimal   @db.Decimal(12, 2)
  fecha          DateTime  @default(now())

  negocio  Negocio  @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  cobros CobroFiado[]

  @@index([negocioId, fecha])
}

model CobroFiado {
  id              String   @id @default(uuid())
  negocioId       String
  ventaId         String
  montoRecuperado Decimal  @db.Decimal(12, 2)
  fechaCobro      DateTime @default(now())

  negocio Negocio  @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  venta   VentaDia @relation(fields: [ventaId], references: [id])

  @@index([negocioId])
  @@index([ventaId])
}

model GastoDia {
  id          String   @id @default(cuid())
  negocioId   String
  monto       Decimal  @db.Decimal(10,2)
  descripcion String?
  fecha       DateTime @default(now())

  negocio Negocio @relation(fields: [negocioId], references: [id])
}

model EfectivoCaja {
  id        String   @id @default(uuid())
  negocioId String
  fecha     DateTime @db.Date
  monto     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([negocioId, fecha])
  @@index([negocioId, fecha])
}
