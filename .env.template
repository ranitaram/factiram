# === BASE DE DATOS ===
# PostgreSQL (Neon recomendado). DATABASE_URL usa pooler, DIRECT_URL es directo.
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?pgbouncer=true&connect_timeout=10"
DIRECT_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb"

# === AUTENTICACIÓN ===
# Generar con: openssl rand -base64 32
FACTIRAM_AUTH_SECRET="tu-secreto-aqui"
NEXTAUTH_SECRET="tu-secreto-aqui"
NEXTAUTH_URL="http://localhost:3000"

# === ADMIN PANEL ===
# Contraseña para acceder a /admin-factiram
ADMIN_SECRET="tu-contraseña-admin"

# === URL DE LA APP ===
# En desarrollo: http://localhost:3000 | En producción: https://factiram.com
APP_URL="http://localhost:3000"

# === GOOGLE AUTH ===
# Credenciales de Google Cloud Console (OAuth 2.0)
GOOGLE_CLIENT_ID="xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxx"

# === MERCADO PAGO ===
